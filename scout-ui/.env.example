# Scout frontend environment template. Copy to scout-ui/.env for local
# dev; set the same keys as Vercel env vars for production and as EAS
# env vars for native builds.
#
# Only keys prefixed EXPO_PUBLIC_ are inlined into the client bundle.

# Backend base URL. Consumed by scout-ui/lib/config.ts and re-exported
# as API_BASE_URL to every module that talks to the Scout API. Required
# at build time for any non-local deploy — missing value falls back to
# http://localhost:8000, which will not resolve on a phone.
EXPO_PUBLIC_API_URL=http://localhost:8000

# UNUSED — not read by any scout-ui code today. Retained only because
# it is already set on Vercel. Slated for removal in a follow-up PR.
EXPO_PUBLIC_PUSH_PROVIDER=expo
