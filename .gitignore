# (Removed stale "settings/" rule — it was catching scout-ui/app/settings/
# as well, which meant the real settings page was never tracked. The
# original intent was probably a long-gone test-output directory.)

# Playwright
smoke-tests/node_modules/
smoke-tests/playwright-report/
smoke-tests/test-results/

# Agent / tooling scratch
# Agent-generated plan files (superpowers and similar tools write plans
# to docs/superpowers/plans/ which are per-session scratch and not part
# of the Scout product).
docs/superpowers/

# Orphan design mockups dropped at the repo root during exploration.
# Keep out of version control so they don't get committed by accident.
scout_mockups.html

# Git worktrees for isolated feature work.
.worktrees/

# Claude Code per-developer settings (permissions, etc.).
# Shared settings belong in .claude/settings.json instead.
.claude/settings.local.json
