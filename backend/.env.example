# Scout backend environment template. Copy to backend/.env for local dev;
# set the same keys as Railway env vars for production.

SCOUT_DATABASE_URL=postgresql://scout:scout@localhost:5432/scout
SCOUT_ENVIRONMENT=development

# AI provider
SCOUT_ANTHROPIC_API_KEY=
SCOUT_AI_CHAT_MODEL=claude-sonnet-4-20250514

# Auth
SCOUT_AUTH_REQUIRED=false
SCOUT_ENABLE_BOOTSTRAP=true

# Supabase Storage (optional — upload endpoints 501 when unset)
SCOUT_SUPABASE_URL=
SCOUT_SUPABASE_SERVICE_ROLE_KEY=
SCOUT_SUPABASE_STORAGE_BUCKET=attachments

# Transcription (optional — transcribe endpoint 501 when unset)
SCOUT_TRANSCRIBE_PROVIDER=groq
SCOUT_TRANSCRIBE_API_KEY=

# Push notifications (Sprint Expansion Phase 1). Keys are intentionally
# unprefixed so they match the frontend's EXPO_PUBLIC_PUSH_PROVIDER and
# Expo's own EXPO_ACCESS_TOKEN convention.
PUSH_PROVIDER=expo
EXPO_PUSH_SECURITY_ENABLED=false
# Only required when EXPO_PUSH_SECURITY_ENABLED=true. Issue from the
# Expo dashboard (Account Settings → Access Tokens).
EXPO_ACCESS_TOKEN=
