# Scout Backend Environment Variables
# Copy to .env and fill in values

# Required
SCOUT_DATABASE_URL=postgresql://scout:scout@localhost:5432/scout

# Environment: "development" or "production"
# Production enforces auth_required=true, non-localhost CORS
SCOUT_ENVIRONMENT=development

# Auth
SCOUT_AUTH_REQUIRED=false
SCOUT_SESSION_TTL_HOURS=72
SCOUT_ENABLE_BOOTSTRAP=true

# CORS (comma-separated)
SCOUT_CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# AI (optional)
SCOUT_ANTHROPIC_API_KEY=
SCOUT_ENABLE_AI=true
SCOUT_ENABLE_MEAL_GENERATION=true

# Feature flags
SCOUT_ENABLE_PARENT_ACTION_INBOX=true
