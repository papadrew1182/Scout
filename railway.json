{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd backend && bash start.sh",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
